{
  "name": "metabot",
  "version": "1.0.0",
  "description": "MetaBot — Bridge service connecting IM bots (Feishu/Lark, Telegram) to Claude Code Agent SDK",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:web && tsc && cp -r src/memory/static dist/memory/static",
    "build:web": "cd web && npm install --include=dev && ./node_modules/.bin/vite build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "update-cli": "for cli in mb mm metabot; do [ -f bin/$cli ] && cp bin/$cli ~/.local/bin/$cli && chmod +x ~/.local/bin/$cli && echo \"Updated: $cli\"; done"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.140",
    "@anthropic-ai/sdk": "^0.78.0",
    "@larksuiteoapi/node-sdk": "^1.58.0",
    "@moonshot-ai/kimi-agent-sdk": "^0.1.8",
    "@types/ws": "^8.18.0",
    "@volcengine/openapi": "^1.36.0",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.40.0",
    "https-proxy-agent": "^7.0.6",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "node-edge-tts": "^1.2.10",
    "openai": "^6.29.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "undici": "^7.24.5",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
